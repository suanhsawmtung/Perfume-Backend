generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            Int               @id @default(autoincrement())
  name          String            @db.VarChar(255)
  slug          String            @unique @db.VarChar(255)
  concentration Concentration
  gender        Gender
  description   String
  rating        Decimal           @default(0) @db.Decimal(2, 1)
  ratingCount   Int               @default(0)
  isActive      Boolean           @default(true)
  isLimited     Boolean           @default(false)
  releasedYear  Int?
  brandId       Int
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  brand         Brand             @relation(fields: [brandId], references: [id])
  ratings       ProductRating[]
  variants      ProductVariant[]
  wishlists     ProductWishlist[]
  reviews       Review[]
}

model ProductVariant {
  id          Int             @id @default(autoincrement())
  slug        String          @unique @db.VarChar(255)
  productId   Int
  sku         String          @unique
  size        Int
  source      VariantSource   @default(ORIGINAL)
  price       Decimal         @db.Decimal(10, 2)
  discount    Decimal         @default(0) @db.Decimal(10, 2)
  stock       Int             @default(0)
  isPrimary   Boolean         @default(false)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?
  bundleSets  BundleSetItem[]
  images      Image[]
  inventories Inventory[]
  product     Product         @relation(fields: [productId], references: [id])
}

model Inventory {
  id               Int            @id @default(autoincrement())
  productVariantId Int
  quantity         Int            @default(0)
  reserved         Int            @default(0)
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])
}

model Image {
  id               Int             @id @default(autoincrement())
  path             String          @db.VarChar(255)
  isPrimary        Boolean         @default(false)
  order            Int             @default(0)
  productVariantId Int?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
}

model Review {
  id        Int      @id @default(autoincrement())
  content   String
  isPublish Boolean  @default(false)
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
}

model BundleSet {
  id          Int             @id @default(autoincrement())
  name        String          @db.VarChar(255)
  slug        String          @unique @db.VarChar(255)
  gender      Gender
  status      Status          @default(ACTIVE)
  description String?
  price       Decimal         @db.Decimal(10, 2)
  discount    Decimal         @default(0) @db.Decimal(10, 2)
  stock       Int             @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  items       BundleSetItem[]
}

model BundleSetItem {
  id               Int            @id @default(autoincrement())
  bundleSetId      Int
  productVariantId Int
  quantity         Int            @default(1) @db.SmallInt
  bundleSet        BundleSet      @relation(fields: [bundleSetId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@unique([bundleSetId, productVariantId])
}

model Order {
  id              Int                @id @default(autoincrement())
  userId          Int
  code            String             @unique @db.VarChar(15)
  totalPrice      Decimal            @db.Decimal(10, 2)
  status          OrderStatus        @default(PENDING)
  source          OrderSource        @default(CUSTOMER)
  customerName    String?            @db.VarChar(100)
  customerPhone   String?            @db.VarChar(15)
  customerAddress String?            @db.VarChar(255)
  customerNotes   String?            @db.VarChar(500)
  rejectedReason  String?            @db.VarChar(500)
  cancelledReason String?            @db.VarChar(500)
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  paymentStatus   OrderPaymentStatus @default(PENDING)
  user            User               @relation(fields: [userId], references: [id])
  orderItems      OrderItem[]
  payments        Payment[]
  refunds         Refund[]
}

model OrderItem {
  id        Int           @id @default(autoincrement())
  orderId   Int
  itemId    Int
  itemType  OrderItemType
  quantity  Int           @db.SmallInt
  price     Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())
  order     Order         @relation(fields: [orderId], references: [id])

  @@index([itemId, itemType])
}

model Payment {
  id        String        @id @default(cuid())
  orderId   Int
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  reference String?
  note      String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  order     Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Refund {
  id        Int          @id @default(autoincrement())
  orderId   Int
  amount    Decimal      @db.Decimal(10, 2)
  reason    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  status    RefundStatus @default(PENDING)
  order     Order        @relation(fields: [orderId], references: [id])
}

model Otp {
  id            Int      @id @default(autoincrement())
  email         String   @unique @db.VarChar(255)
  otp           String
  rememberToken String
  verifyToken   String?
  count         Int      @default(0) @db.SmallInt
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  error         Int      @default(0) @db.SmallInt
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(52)
  slug      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  posts     Post[]
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  excerpt     String?    @db.VarChar(255)
  content     String
  image       String
  authorId    Int
  categoryId  Int
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  author      User       @relation(fields: [authorId], references: [id])
  category    Category   @relation(fields: [categoryId], references: [id])
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(52)
  slug      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  products  Product[]
}

model ProductWishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model ProductRating {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  rating    Int      @db.SmallInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model User {
  id                Int               @id @default(autoincrement())
  firstName         String?           @db.VarChar(52)
  lastName          String?           @db.VarChar(52)
  username          String            @unique @db.VarChar(100)
  phone             String?           @db.VarChar(15)
  password          String
  email             String            @unique @db.VarChar(255)
  role              Role              @default(USER)
  status            Status            @default(ACTIVE)
  lastLogin         DateTime?
  errorLoginCount   Int               @default(0) @db.SmallInt
  randToken         String
  previousRandToken String?
  image             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  orders            Order[]
  posts             Post[]
  ratings           ProductRating[]
  wishlists         ProductWishlist[]
  reviews           Review[]
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique @db.VarChar(50)
  value String @db.VarChar(255)
}

enum Role {
  USER
  ADMIN
  AUTHOR
}

enum Status {
  ACTIVE
  INACTIVE
  FREEZE
}

enum OrderStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  DONE
}

enum OrderSource {
  CUSTOMER
  ADMIN
}

enum OrderPaymentStatus {
  UNPAID
  PAID
  PENDING
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Concentration {
  EDC
  EDT
  EDP
  PARFUM
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum BundleAudience {
  MEN
  WOMEN
  COUPLE
  UNISEX
}

enum VariantSource {
  ORIGINAL
  DECANT
}

enum OrderItemType {
  PRODUCT_VARIANT
  BUNDLE
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CARD
  E_WALLET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  VOIDED
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
  VOIDED
}
