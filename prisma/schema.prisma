//   MEN
//   WOMEN
//   COUPLE
//   UNISEX
// }

// enum VariantSource {
//   ORIGINAL
//   DECANT
// }

// enum OrderItemType {
//   PRODUCT_VARIANT
//   BUNDLE
// }

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CARD
  E_WALLET
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  VOIDED
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
  VOIDED
}

enum TransactionDirection {
  IN // money in
  OUT // money out
}

enum TransactionType {
  PAYMENT
  REFUND
  ADJUSTMENT
  REVERSAL
  EXPENSE
  WITHDRAWAL
  OTHER
}

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
}

enum InventoryType {
  PURCHASE
  SALE
  DAMAGED
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_FROM_CUSTOMER
  RETURN_TO_SUPPLIER
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum OtpType {
  VERIFY_EMAIL
  RESET_PASSWORD
}
