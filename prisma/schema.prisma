model Order {
  id              Int                @id @default(autoincrement())
  userId          Int
  code            String             @unique @db.VarChar(15)
  totalPrice      Decimal            @db.Decimal(10, 2)
  status          OrderStatus        @default(PENDING)
  source          OrderSource        @default(CUSTOMER)
  customerName    String?            @db.VarChar(100)
  customerPhone   String?            @db.VarChar(15)
  customerAddress String?            @db.VarChar(255)
  customerNotes   String?            @db.VarChar(500)
  rejectedReason  String?            @db.VarChar(500)
  cancelledReason String?            @db.VarChar(500)
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  paymentStatus   OrderPaymentStatus @default(UNPAID)
  user            User               @relation(fields: [userId], references: [id])
  orderItems      OrderItem[]
  payments        Payment[]
  refunds         Refund[]
  reservations    Reservation[]
}

model OrderItem {
  id               Int           @id @default(autoincrement())
  orderId          Int
  productVariantId Int
  quantity         Int           @db.SmallInt
  price            Decimal       @db.Decimal(10, 2)
  createdAt        DateTime      @default(now())
  order            Order         @relation(fields: [orderId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([productVariantId])
}

model Payment {
  id        Int           @id @default(autoincrement())
  orderId   Int
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  status    PaymentStatus @default(PENDING)
  reference String?       @db.VarChar(255)
  note      String?       @db.VarChar(255)
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?
  order     Order         @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Refund {
  id        Int          @id @default(autoincrement())
  orderId   Int
  amount    Decimal      @db.Decimal(10, 2)
  reason    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?
  status    RefundStatus @default(PENDING)
  order     Order        @relation(fields: [orderId], references: [id])
}

model Transaction {
  id Int @id @default(autoincrement())

  // Core
  type      TransactionType
  direction TransactionDirection
  amount    Decimal              @db.Decimal(12, 2)
  // currency    String               @default("USD")

  // Optional info
  source    String // REQUIRED: where money comes from
  reference String? // receipt / external reference
  note      String?

  // Audit
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy User? @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([direction])
}

model Otp {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  otp        String
  token      String?
  type       OtpType
  verifiedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(52)
  slug      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  posts     Post[]
}

model Post {
  id          Int        @id @default(autoincrement())
  title       String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  excerpt     String?    @db.VarChar(255)
  content     String
  image       String
  authorId    Int
  categoryId  Int
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  author      User       @relation(fields: [authorId], references: [id])
  category    Category   @relation(fields: [categoryId], references: [id])
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(52)
  slug      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  products  Product[]
}

model ProductWishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model User {
  id              Int       @id @default(autoincrement())
  firstName       String?   @db.VarChar(52)
  lastName        String?   @db.VarChar(52)
  username        String    @unique @db.VarChar(100)
  phone           String?   @db.VarChar(15)
  password        String?
  email           String    @unique @db.VarChar(255)
  image           String?
  emailVerifiedAt DateTime?

  role   Role   @default(USER)
  status Status @default(ACTIVE)

  googleId String?      @unique
  provider AuthProvider @default(EMAIL)

  refreshToken         String?
  previousRefreshToken String?

  rotateTokenAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  orders       Order[]
  posts        Post[]
  wishlists    ProductWishlist[]
  reviews      Review[]
  transactions Transaction[]
  inventories  Inventory[]
}

enum Role {
  USER
  ADMIN
  AUTHOR
}

enum Status {
  ACTIVE
  INACTIVE
  FREEZE
}

enum OrderStatus {
  PENDING
  ACCEPTED
  SHIPPED
  DELIVERED
  DONE
  REJECTED
  CANCELLED
}

enum OrderSource {
  CUSTOMER
  ADMIN
}

enum OrderPaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum Concentration {
  EDC
  EDT
  EDP
  PARFUM
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

